# Streamlit Cloud secrets
# Copy this file to .streamlit/secrets.toml locally OR paste these keys into
# the Streamlit Community Cloud "Secrets" UI when you create the app.
#
# The Telegram bot token is NOT needed here — only the bot process needs it.
# The dashboard needs only the gist ID (and optionally a token for rate limits).

BET_TRACKER_GIST_ID = "paste_the_gist_id_here"

# Optional: PAT with no scopes needed for public gists (bumps API rate limit
# from 60/hr unauth to 5000/hr auth). Only set if you want that ceiling.
# GITHUB_TOKEN = "ghp_..."
